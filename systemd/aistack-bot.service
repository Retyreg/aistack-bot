[Unit]
Description=AIstack funnel bot
After=network.target postgresql.service

[Service]
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/apps/aistack-bot
ExecStart=/home/deploy/apps/aistack-bot/.venv/bin/python bot.py
Restart=always
RestartSec=5
EnvironmentFile=/home/deploy/apps/aistack-bot/.env

[Install]
WantedBy=multi-user.target
